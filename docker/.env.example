# =============================================================================
# StealthOS Relay Server — Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your deployment.
# Variables here are used by docker-compose.yml and override config file values.

# ---------------------------------------------------------------------------
# Docker Compose port mappings
# ---------------------------------------------------------------------------

# Host port for the WebSocket listener.
STEALTH_WS_PORT=9090

# Host port for the internal health/metrics endpoint.
STEALTH_METRICS_PORT=9091

# ---------------------------------------------------------------------------
# Server configuration overrides
# ---------------------------------------------------------------------------

# Log level: trace, debug, info, warn, error
STEALTH_LOG_LEVEL=info

# Log format: json (production) or pretty (development)
STEALTH_LOG_FORMAT=json

# Override bind addresses (useful for non-default ports).
# STEALTH_SERVER__WS_BIND=0.0.0.0:9090
# STEALTH_SERVER__METRICS_BIND=0.0.0.0:9091

# Override connection limits.
# STEALTH_SERVER__MAX_CONNECTIONS=500
# STEALTH_SERVER__MAX_MESSAGE_SIZE=65536
# STEALTH_SERVER__IDLE_TIMEOUT=600

# Override pool limits.
# STEALTH_POOL__MAX_POOLS=100
# STEALTH_POOL__MAX_POOL_SIZE=16
# STEALTH_POOL__POOL_IDLE_TIMEOUT=300

# Override rate limits.
# STEALTH_RATE_LIMIT__CONNECTIONS_PER_MINUTE=30
# STEALTH_RATE_LIMIT__MESSAGES_PER_SECOND=60
# STEALTH_RATE_LIMIT__MAX_FAILED_AUTH=5
# STEALTH_RATE_LIMIT__BLOCK_DURATION_SECS=600

# Override crypto settings.
# STEALTH_CRYPTO__KEY_DIR=/var/stealth-relay/keys
# STEALTH_CRYPTO__AUTO_GENERATE_KEYS=true

# ---------------------------------------------------------------------------
# Cloudflare Tunnel (only needed with docker-compose.cloudflared.yml)
# ---------------------------------------------------------------------------

# Tunnel token from: cloudflared tunnel create stealth-relay
# CLOUDFLARED_TOKEN=